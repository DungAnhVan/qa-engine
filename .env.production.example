# =============================================================================
# Quanta Aptus Admin — Production Environment Template
# Gate 63 — Production Deployment Prep
# =============================================================================
#
# IMPORTANT:
#   - NEVER commit a real .env.production file to git.
#   - Copy this file and fill in real values only in the Vercel dashboard
#     or your secure secrets manager.
#   - NEXT_PUBLIC_* values are exposed to the browser — never put secrets there.
#   - SUPABASE_SERVICE_ROLE_KEY is server-side only (never put in NEXT_PUBLIC_*).
#
# HOW TO USE:
#   1. Go to Vercel Project → Settings → Environment Variables.
#   2. Add each variable below with its real value.
#   3. Redeploy after adding all variables.
# =============================================================================

# ---------------------------------------------------------------------------
# App mode
# ---------------------------------------------------------------------------
QA_CONTENT_SOURCE=live_supabase
QA_AUTH_DEMO_FALLBACK=false

# ---------------------------------------------------------------------------
# Node environment
# ---------------------------------------------------------------------------
NODE_ENV=production

# ---------------------------------------------------------------------------
# Supabase — server-side only (NOT exposed to browser)
# ---------------------------------------------------------------------------
# Find in: Supabase Dashboard → Project Settings → API → URL
SUPABASE_URL=

# Find in: Supabase Dashboard → Project Settings → API → anon key
# (used for server-side SSR session reads without service role)
SUPABASE_ANON_KEY=

# Find in: Supabase Dashboard → Project Settings → API → service_role key
# CRITICAL: NEVER expose this in NEXT_PUBLIC_* or client-side code.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Supabase — browser-visible (safe to expose via NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
# Same URL as SUPABASE_URL — duplicated so browser can also read it
NEXT_PUBLIC_SUPABASE_URL=

# Same as SUPABASE_ANON_KEY — anon key is browser-safe (not a secret)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# AI Content Factory — Gate 69B+
# ---------------------------------------------------------------------------
# AI provider for question generation pipeline (server/CLI only)
# mock | openai | anthropic
QA_AI_PROVIDER=mock

# Set to false only when a real provider key is available and generation is enabled
QA_AI_DRY_RUN=true

# Block raw Cambridge source text from AI input (recommended: always true)
QA_AI_COPYRIGHT_STRICT=true

# OpenAI API key — NEVER put this in a NEXT_PUBLIC_* variable
# Leave empty in production until AI generation is enabled
OPENAI_API_KEY=

# Anthropic API key — NEVER put this in a NEXT_PUBLIC_* variable
# Leave empty in production until AI generation is enabled
ANTHROPIC_API_KEY=

# OpenAI model override (Gate 70A) — default: gpt-4o-mini
QA_OPENAI_MODEL=

# Anthropic model override (Gate 70A) — default: claude-haiku-4-5-20251001
QA_ANTHROPIC_MODEL=
