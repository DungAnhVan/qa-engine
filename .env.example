# Quanta Aptus — Environment Variables Template
# Copy this file to .env.local and fill in your Supabase project values.
# NEVER commit .env.local or any file containing real keys.
# .env.local is already listed in .gitignore.

# ------------------------------------------------------------------
# Supabase project settings
# Find these at: https://supabase.com/dashboard/project/<ref>/settings/api
# ------------------------------------------------------------------

# Project URL  e.g. https://abcdefghij.supabase.co
SUPABASE_URL=

# Anon (public) key — safe to use in browser/client-side code
SUPABASE_ANON_KEY=

# Service Role key — server-side ONLY. Never expose to browser.
# Used for migration verification and pipeline scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Database password — set during project creation
SUPABASE_DB_PASSWORD=

# Project ref — the short ID in your project URL
# e.g. for https://abcdefghij.supabase.co -> abcdefghij
SUPABASE_PROJECT_REF=

# ------------------------------------------------------------------
# Admin app — content source mode
# Controls whether the admin app reads from local JSON files, from
# the Supabase export snapshot, or from live Supabase.
# The browser NEVER connects to Supabase directly.
# SUPABASE_SERVICE_ROLE_KEY is used server-side only (live_supabase mode).
#
# Values:
#   local            — read from local publish + registry JSON files (default)
#   supabase_export  — read from data/supabase_exports/ snapshot (requires Gate 53F)
#   live_supabase    — live server-side Supabase read (requires SUPABASE_URL + SERVICE_ROLE_KEY)
# ------------------------------------------------------------------

# Default: local (safe — works without Supabase connection)
# local | supabase_export | live_supabase
QA_CONTENT_SOURCE=local

# ------------------------------------------------------------------
# Admin app — browser / client-side Supabase (anon key only)
# Required for Gate 61+ login UI.
# These are NEXT_PUBLIC_ so they are included in the browser bundle.
# Use the ANON key here — never the service role key.
# ------------------------------------------------------------------

# Same value as SUPABASE_URL above, exposed to browser
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------------
# Auth mode — Gate 61+
# ------------------------------------------------------------------

# When true: server components return a static demo auth context
# if no real Supabase Auth session is present.
# Set to false (or omit) in production.
QA_AUTH_DEMO_FALLBACK=true

# ------------------------------------------------------------------
# AI Content Factory — Gate 69B+
# Controls AI-driven question generation pipeline.
# API keys are server/CLI only — NEVER put in NEXT_PUBLIC_* vars.
# ------------------------------------------------------------------

# AI provider to use for content generation
# mock | openai | anthropic
QA_AI_PROVIDER=mock

# When true (default): use mock responses, no real API calls made
QA_AI_DRY_RUN=true

# When true (default): block raw Cambridge source text from AI input
QA_AI_COPYRIGHT_STRICT=true

# OpenAI API key — server/CLI only, never expose to browser
# Required only when QA_AI_PROVIDER=openai and QA_AI_DRY_RUN=false
OPENAI_API_KEY=

# Anthropic API key — server/CLI only, never expose to browser
# Required only when QA_AI_PROVIDER=anthropic and QA_AI_DRY_RUN=false
ANTHROPIC_API_KEY=

# OpenAI model override (Gate 70A) — default: gpt-4o-mini
QA_OPENAI_MODEL=

# Anthropic model override (Gate 70A) — default: claude-haiku-4-5-20251001
QA_ANTHROPIC_MODEL=
