# Quanta Aptus — Environment Variables Template
# Copy this file to .env.local and fill in your Supabase project values.
# NEVER commit .env.local or any file containing real keys.
# .env.local is already listed in .gitignore.

# ------------------------------------------------------------------
# Supabase project settings
# Find these at: https://supabase.com/dashboard/project/<ref>/settings/api
# ------------------------------------------------------------------

# Project URL  e.g. https://abcdefghij.supabase.co
SUPABASE_URL=

# Anon (public) key — safe to use in browser/client-side code
SUPABASE_ANON_KEY=

# Service Role key — server-side ONLY. Never expose to browser.
# Used for migration verification and pipeline scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Database password — set during project creation
SUPABASE_DB_PASSWORD=

# Project ref — the short ID in your project URL
# e.g. for https://abcdefghij.supabase.co -> abcdefghij
SUPABASE_PROJECT_REF=
